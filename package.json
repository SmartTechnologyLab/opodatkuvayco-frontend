    "@semantic-release/git": "^10.0.1",
    "@semantic-release/npm": "^13.1.5",
    "@storybook/addon-links": "^10.3.5",
    "@storybook/vue3": "^10.3.5",
    "@storybook/vue3-vite": "^10.3.5",
    "@tailwindcss/postcss": "^4.2.2",
    "@tsconfig/node20": "^20.1.9",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^25.6.0",
