    "eslint": "^10.2.0",
    "eslint-plugin-storybook": "^10.3.5",
    "eslint-plugin-vue": "^10.8.0",
    "husky": "^9.1.7",
    "jsdom": "^29.0.2",
    "lint-staged": "^16.4.0",
    "npm-run-all2": "^8.0.4",
    "prettier": "^3.8.2",
    "sass": "^1.99.0",
